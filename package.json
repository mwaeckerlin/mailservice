{
  "name": "@mwaeckerlin/mailservice",
  "version": "1.0.0",
  "scripts": {
    "build": "docker compose build",
    "start": "docker compose up --build --force-recreate --remove-orphans",
    "start:daemon": "docker compose up -d --build --force-recreate --remove-orphans",
    "start:dev": "docker compose up --build --force-recreate --remove-orphans",
    "start:local": "docker compose -f docker-compose.yml -f docker-compose.local.yml up --build --force-recreate --remove-orphans",
    "start:local:daemon": "docker compose -f docker-compose.yml -f docker-compose.local.yml up -d --build --force-recreate --remove-orphans",
    "stop": "docker compose down",
    "test": "npm run test:e2e",
    "test:e2e": "bash tests/run-e2e.sh"
  }
}